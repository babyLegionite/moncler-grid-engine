; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between brackets
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="moncler-grid-engine"
config/version="0.1.0"
config/description="Halo Reach Hemorrhage Infection — 4-player split-screen in Godot 4. Exact Reach physics, DualShock 4 support, macOS-native."
run/main_scene="res://scenes/HemorrhageInfection.tscn"
config/features=PackedStringArray("4.3")
config/icon="res://icon.svg"

[autoload]

InputManager="*res://scripts/gd/InputManager.gd"
DevTools="*res://scripts/gd/DevTools.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"

[input]

# ---- Left Stick (Movement) ----
move_left={
"deadzone": 0.3,
"events": [Object(InputEventJoypadMotion,"resource_local_to_scene":false,"resource_name":"","device":-1,"axis":0,"axis_value":-1.0,"script":null)
]
}
move_right={
"deadzone": 0.3,
"events": [Object(InputEventJoypadMotion,"resource_local_to_scene":false,"resource_name":"","device":-1,"axis":0,"axis_value":1.0,"script":null)
]
}
move_forward={
"deadzone": 0.3,
"events": [Object(InputEventJoypadMotion,"resource_local_to_scene":false,"resource_name":"","device":-1,"axis":1,"axis_value":-1.0,"script":null)
]
}
move_back={
"deadzone": 0.3,
"events": [Object(InputEventJoypadMotion,"resource_local_to_scene":false,"resource_name":"","device":-1,"axis":1,"axis_value":1.0,"script":null)
